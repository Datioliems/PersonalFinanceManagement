APP_NAME="Quản lý Tài chính Cá nhân"
APP_ENV=development

# Local dev: http://localhost/clone/PersonalFinanceManagement-merged/de13_merged/public
# Production: https://your-domain.com
APP_URL=http://localhost:8000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=de13_finance
DB_USER=root
DB_PASS=

SESSION_NAME=de13_session

# true = bắt đăng nhập | false = dùng Guest account
AUTH_ENABLED=true

# Mail settings (leave blank if not using email features yet)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
MAIL_FROM_NAME=FinanceApp
MAIL_DEBUG=0
