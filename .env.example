# ============================================================
# ENVIRONMENT CONFIGURATION — Đề 13: Quản lý Tài chính
# ============================================================
# Sao chép file này thành .env rồi điền thông tin thực tế
# KHÔNG commit file .env lên Git
# ============================================================

APP_NAME="Quản lý Tài chính Cá nhân"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=de13_finance
DB_USER=root
DB_PASS=

# --- Session ---
SESSION_NAME=de13_session
SESSION_LIFETIME=7200

# --- Security ---
# Tạo bằng: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=CHANGE_THIS_TO_RANDOM_64_CHAR_HEX
